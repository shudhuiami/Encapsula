{
    "name": "zobayer/encapsula",
    "description": "Laravel API response encryption middleware with frontend decoding support.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "encryption",
        "api",
        "middleware",
        "response-encryption",
        "aes-gcm",
        "security",
        "frontend-decoding"
    ],
    "authors": [
        {
            "name": "Ahmed Zobayer",
            "email": "shudhuiami@users.noreply.github.com"
        }
    ],
    "homepage": "https://github.com/shudhuiami/Encapsula",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/validation": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zobayer\\Encapsula\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zobayer\\Encapsula\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zobayer\\Encapsula\\EncapsulaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
